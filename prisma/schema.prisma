// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


model Invoice {
  id           String   @id @default(cuid())
  invoiceNo    String   @unique
  companyName  String
  customerName String // Keep for snapshot
  
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  
  // Link to Employee who created it
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id])

  totalAmount  Float
  date         DateTime
  paymentMode  String
  status       String   @default("PAID") // PAID, PENDING, CANCELLED
  
  // Payment tracking
  dueDate      DateTime?
  paidAmount   Float    @default(0)
  
  // JSON fields for structured data that doesn't need its own table for MVP
  customerDetails String // JSON string of customer object
  billingAddress  String
  
  items        InvoiceItem[]
  
  // New relations for distribution features
  payments     Payment[]
  salesReturns SalesReturn[]
  reminders    PaymentReminder[]
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  productId   String
  description String
  quantity    Int
  price       Float
  costPrice   Float   @default(0) // For profit calc
  hsn         String?
  gstRate     Float   @default(18.0)
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  role        String   // ADMIN, EMPLOYEE, DRIVER, etc.
  password    String   // Hashed
  
  // Multi-tenancy & Employee Link
  companyName String?  // If null, might be Super Admin or unassigned
  employeeId  String?  // Link to Employee record if applicable
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Employee {
  id          String   @id @default(cuid())
  companyName String   // Separation
  employeeId  String    // Custom ID e.g., EMP-001
  
  name        String
  role        String   // Job Role: "Driver", "Sales Officer", "Manager"
  email       String?
  phone       String?
  address     String?
  aadhaar     String?
  pan         String?
  
  // Payroll Info
  salaryType  String   @default("MONTHLY") // "MONTHLY", "DAILY"
  baseSalary  Float    @default(0)
  
  // Status
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  joiningDate DateTime @default(now())
  
  // Relations
  attendance Attendance[]
  invoices   Invoice[]
  payroll    Payroll[]
  
  // New relations for distribution features
  beats      Beat[]
  visits     Visit[]
  orders     Order[]
  vanLoads   VanLoad[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyName, employeeId]) // IDs unique per company or globally? Let's keep unique
}

model Attendance {
  id          String   @id @default(cuid())
  employeeId  String   
  employee    Employee @relation(fields: [employeeId], references: [id])
  
  date        DateTime // Store as date only (midnight)
  status      String   // PRESENT, ABSENT, HALF_DAY, LEAVE
  
  checkIn     String?  // Time string "09:00"
  checkOut    String?  // Time string "18:00"
  
  overtimeHours Float  @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, date])
}

model Payroll {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  
  month       String   // "2024-12"
  year        Int
  
  baseSalary  Float
  attendanceDays Float // Present days
  
  // Earnings
  earnedSalary Float
  bonus        Float   @default(0) // Performance/Trip Bonus
  incentives   Float   @default(0) // Sales Commission (Legacy/Future)
  
  // Deductions
  deductions   Float   @default(0)
  
  netSalary    Float
  
  status       String  @default("PENDING") // PENDING, PAID
  paymentDate  DateTime?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeId, month])
}

model Product {
  id          String   @id @default(cuid())
  companyName String   @default("Sai Associates")
  sku         String   @unique
  name        String
  category    String   @default("General")
  price       Float
  stock       Int      @default(0)
  image       String?  // Emoji or URL
  minStock    Int      @default(10) // Low stock alert threshold
  costPrice     Float    @default(0)
  reorderQuantity Int    @default(50) // Default batch size to order
  supplierEmail   String? // For auto-restock alerts
  isLiquidationCandidate Boolean @default(false)
  liquidationFlaggedAt DateTime?
  liquidationReason String?
  
  gstRate       Float    @default(18.0)
  
  stocks        Stock[]  // Relation to Stock model
  
  // New relations for distribution features
  orderItems    OrderItem[]
  vanLoadItems  VanLoadItem[]
  returnItems   ReturnItem[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Godown {
  id          String   @id @default(cuid())
  name        String   @unique
  location    String?
  manager     String?
  contact     String?
  
  stocks      Stock[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stock {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  godownId    String
  godown      Godown   @relation(fields: [godownId], references: [id], onDelete: Cascade)
  
  quantity    Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, godownId])
}

model Customer {
  id        String   @id @default(cuid())
  companyName String @default("Sai Associates")
  name      String   
  address   String
  state     String
  gstin     String?  @unique
  phone     String?
  email     String?
  
  // Location
  lat       Float?
  lng       Float?
  mapLink   String?
  
  balance      Float    @default(0)
  totalRevenue Float    @default(0)
  
  invoices      Invoice[]
  lastInvoiceNo String?
  
  // New relations for distribution features
  beatCustomers    BeatCustomer[]
  visits           Visit[]
  orders           Order[]
  credit           CustomerCredit?
  payments         Payment[]
  reminders        PaymentReminder[]
  salesReturns     SalesReturn[]
  creditNotes      CreditNote[]
  vanSales         VanSale[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  address     String
  city        String?
  state       String?
  pincode     String?
  phone       String?
  email       String?
  gstin       String?
  
  // Bank Details
  bankName    String?
  accountNo   String?
  ifscCode    String?
  branch      String?
  
  // Assets
  logoUrl     String?  // Base64 or URL
  signatureUrl String? // Base64 or URL
  
  // Communication Config
  whatsappApiKey String?
  whatsappPhoneId String?
  invoiceTemplateId String? // For WhatsApp template
  
  emailSmtpHost String?
  emailUser     String?
  emailPassword String?

  // E-Way Bill Configuration
  ewayProvider            String?
  ewayEnvironment         String          @default("SANDBOX")
  ewayEnabled             Boolean         @default(false)
  ewayClientId            String?
  ewayClientSecret        String?
  ewayUsername            String?
  ewayPassword            String?
  ewayGstin               String?
  ewayCredentialUpdatedAt DateTime?
  ewayLastTestedAt        DateTime?
  ewayLastTestStatus      String?
  ewayLastTestMessage     String?

  ewayAuditLogs EWayAuditLog[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EWayAuditLog {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  action    String
  status    String
  message   String?
  provider  String?
  createdAt DateTime  @default(now())

  @@index([companyId, createdAt])
}

model Trip {
  id            String    @id @default(cuid())
  companyName   String    @default("Sai Associates")
  driverName    String
  vehicleNo     String
  
  vehicleId     String?
  vehicle       Vehicle?  @relation(fields: [vehicleId], references: [id])

  status        String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  
  startTime     DateTime?
  endTime       DateTime?
  startLocation String?   // JSON {lat, lng}
  totalDistance Float     @default(0)
  
  stops         TripStop[]
  
  // Expenses
  fuelCost      Float     @default(0)
  foodCost      Float     @default(0)
  otherExp      Float     @default(0)
  allowance     Float     @default(0)
  
  startReading  Float     @default(0) // Odometer
  endReading    Float     @default(0) // Odometer
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TripStop {
  id           String    @id @default(cuid())
  tripId       String
  trip         Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  
  customerName String
  address      String
  items        String    // Description of items
  
  status       String    @default("PENDING") // PENDING, DELIVERED, FAILED
  timestamp    DateTime? // Delivery time
  
  lat          Float
  lng          Float
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Vehicle {
  id          String   @id @default(cuid())
  regNo       String   @unique // e.g., TN-01-AB-1234
  model       String   // e.g., Tata Ace, Hero Splendor
  type        String   // TRUCK, BIKE, AUTO
  status      String   @default("ACTIVE") // ACTIVE, MAINTENANCE, INACTIVE
  fuelType    String?  // DIESEL, PETROL, EV
  
  // Stats
  totalDistance Float  @default(0)
  lastServiceDate DateTime?
  
  details     String? // JSON extra details

  trips       Trip[]
  vanLoads    VanLoad[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Photo {
  id          String   @id @default(cuid())
  url         String   // Base64 or separate storage URL
  timestamp   DateTime @default(now())
  
  // Geolocation
  lat         Float
  lng         Float
  address     String?
  accuracy    Float?
  isMock      Boolean  @default(false)
  
  // Stock snapshot at capture time (e.g. [{ productId, name, qty }])
  stockSnapshot String? // JSON
  
  // Metadata
  userName    String
  userRole    String
  companyName String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// BEAT PLANNING & ROUTE OPTIMIZATION MODELS
// ============================================

model Beat {
  id           String   @id @default(cuid())
  companyName  String
  name         String
  description  String?
  dayOfWeek    Int      // 0=Sunday, 1=Monday, etc. -1 for all days
  
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  
  customers    BeatCustomer[]
  
  isActive     Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([companyName, name, dayOfWeek])
}

model BeatCustomer {
  id          String   @id @default(cuid())
  beatId      String
  beat        Beat     @relation(fields: [beatId], references: [id], onDelete: Cascade)
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  
  sequence    Int      // Visit order in the beat
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([beatId, customerId])
}

model Visit {
  id           String   @id @default(cuid())
  companyName  String
  
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  
  beatId       String?
  
  // Check-in details
  checkInTime  DateTime
  checkInLat   Float
  checkInLng   Float
  
  // Check-out details
  checkOutTime DateTime?
  checkOutLat  Float?
  checkOutLng  Float?
  
  // Visit outcome
  status       String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, SKIPPED, NO_ORDER
  notes        String?
  photoIds     String?  // JSON array of photo IDs
  
  // Linked order if created during visit
  orderId      String?
  
  duration     Int?     // Duration in minutes
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// ORDER MANAGEMENT MODELS
// ============================================

model Order {
  id            String   @id @default(cuid())
  orderNo       String   @unique
  companyName   String
  
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  
  // Order status workflow
  status        String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, DISPATCHED, DELIVERED, CANCELLED
  
  // Amounts
  subtotal      Float
  discountAmount Float   @default(0)
  schemeDiscount Float   @default(0)
  taxAmount     Float    @default(0)
  totalAmount   Float
  
  // Approval workflow
  approvedBy    String?
  approvedAt    DateTime?
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectionReason String?
  
  // Dispatch & Delivery
  dispatchedAt  DateTime?
  deliveredAt   DateTime?
  deliveryNotes String?
  
  // Link to invoice after conversion
  invoiceId     String?
  
  items         OrderItem[]
  appliedSchemes OrderScheme[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  
  quantity    Int
  price       Float
  discount    Float   @default(0)
  gstRate     Float   @default(18.0)
  total       Float
}

// ============================================
// SCHEMES & PROMOTIONS MODELS
// ============================================

model Scheme {
  id           String   @id @default(cuid())
  companyName  String
  name         String
  description  String?
  
  // Scheme type
  type         String   // QUANTITY_DISCOUNT, BUY_X_GET_Y, FLAT_DISCOUNT, PERCENTAGE_DISCOUNT, COMBO
  
  // Conditions for eligibility
  minQuantity  Int?     // Minimum quantity to trigger
  minAmount    Float?   // Minimum order amount to trigger
  buyQuantity  Int?     // For buy X get Y schemes
  getQuantity  Int?     // Free items count
  
  // Benefits
  discountPercent Float?
  discountAmount  Float?
  freeProductId   String? // For free product schemes
  
  // Validity period
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean  @default(true)
  
  // Targeting (JSON arrays, null = applies to all)
  applicableProducts  String? // JSON array of product IDs
  applicableCustomers String? // JSON array of customer IDs
  customerTiers       String? // JSON array: ["A", "B", "C"]
  applicableCategories String? // JSON array of product categories
  
  // Budget control
  budget       Float?   // Maximum budget for this scheme
  usedBudget   Float    @default(0)
  maxUsagePerCustomer Int? // Limit per customer
  
  appliedOrders OrderScheme[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([companyName, name])
}

model OrderScheme {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  schemeId    String
  scheme      Scheme  @relation(fields: [schemeId], references: [id])
  
  discount    Float
  description String? // Human-readable description of benefit applied
}

// ============================================
// CREDIT & COLLECTION MANAGEMENT MODELS
// ============================================

model CustomerCredit {
  id            String   @id @default(cuid())
  
  customerId    String   @unique
  customer      Customer @relation(fields: [customerId], references: [id])
  
  creditLimit   Float    @default(0)
  currentBalance Float   @default(0) // Outstanding amount owed
  availableCredit Float  @default(0) // creditLimit - currentBalance
  
  lastPaymentDate DateTime?
  lastPaymentAmount Float?
  
  creditDays    Int      @default(30) // Payment terms
  tier          String   @default("C") // A, B, C classification
  
  isBlocked     Boolean  @default(false)
  blockReason   String?
  blockedAt     DateTime?
  riskActions   CreditLimitAction[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CreditLimitAction {
  id                String   @id @default(cuid())
  customerCreditId  String
  customerCredit    CustomerCredit @relation(fields: [customerCreditId], references: [id], onDelete: Cascade)
  companyName       String
  previousLimit     Float
  newLimit          Float
  riskScore         Float
  policyAction      String   // REDUCE_LIMIT, MONITOR, INCREASE_ELIGIBLE
  reason            String?
  notificationStatus String  @default("PENDING") // PENDING, SENT, FAILED
  createdAt         DateTime @default(now())

  @@index([companyName, createdAt])
}

model Payment {
  id           String   @id @default(cuid())
  companyName  String
  paymentNo    String   @unique
  
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  
  invoiceId    String?
  invoice      Invoice? @relation(fields: [invoiceId], references: [id])
  
  amount       Float
  mode         String   // CASH, CHEQUE, UPI, BANK_TRANSFER, NEFT, RTGS
  reference    String?  // Cheque number, UTR, transaction ID
  
  // For cheques / PDC
  chequeNo     String?
  chequeDate   DateTime?
  bankName     String?
  
  status       String   @default("RECEIVED") // RECEIVED, DEPOSITED, CLEARED, BOUNCED, CANCELLED
  
  collectedBy  String?  // Employee ID who collected
  collectedAt  DateTime @default(now())
  
  notes        String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PaymentReminder {
  id           String   @id @default(cuid())
  companyName  String
  
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  
  invoiceId    String?
  invoice      Invoice? @relation(fields: [invoiceId], references: [id])
  
  dueAmount    Float
  dueDate      DateTime
  daysPastDue  Int      @default(0)
  
  // Message content
  messageText  String?  // Generated message with invoice details
  
  // Delivery details
  channel      String   // WHATSAPP, SMS, EMAIL
  phoneNumber  String?
  
  // Tracking
  sentAt       DateTime?
  deliveredAt  DateTime?
  status       String   @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  errorMessage String?
  
  // Reminder sequence
  reminderType String   @default("FIRST") // FIRST, SECOND, THIRD, FINAL
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReminderTemplate {
  id           String   @id @default(cuid())
  companyName  String
  name         String
  
  type         String   // PAYMENT_DUE, FIRST_REMINDER, SECOND_REMINDER, FINAL_NOTICE
  
  // Template with placeholders
  messageTemplate String // {customerName}, {invoiceNo}, {amount}, {dueDate}, {daysPastDue}, {itemsList}
  
  // Trigger timing (days relative to due date)
  triggerDays  Int      @default(0) // 0 = on due date, 7 = 7 days after, -3 = 3 days before
  
  isActive     Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([companyName, name])
}

// ============================================
// RETURNS & CLAIMS MANAGEMENT MODELS
// ============================================

model SalesReturn {
  id           String   @id @default(cuid())
  returnNo     String   @unique
  companyName  String
  
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  
  invoiceId    String?
  invoice      Invoice? @relation(fields: [invoiceId], references: [id])
  
  reason       String   // DAMAGED, EXPIRED, WRONG_ITEM, QUALITY_ISSUE, EXCESS_STOCK
  description  String?
  
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  
  totalAmount  Float
  
  // Approval workflow
  approvedBy   String?
  approvedAt   DateTime?
  rejectedBy   String?
  rejectedAt   DateTime?
  rejectionReason String?
  
  // Stock adjustment
  stockAdjusted Boolean @default(false)
  
  items        ReturnItem[]
  
  // Link to credit note
  creditNoteId String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReturnItem {
  id          String      @id @default(cuid())
  returnId    String
  return      SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product     @relation(fields: [productId], references: [id])
  
  quantity    Int
  price       Float
  total       Float
  reason      String?
  condition   String?     // GOOD, DAMAGED, EXPIRED
}

model CreditNote {
  id           String   @id @default(cuid())
  creditNoteNo String   @unique
  companyName  String
  
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  
  returnId     String?  // Link to sales return if applicable
  
  amount       Float
  reason       String
  
  status       String   @default("ISSUED") // ISSUED, PARTIALLY_USED, USED, EXPIRED, CANCELLED
  usedAmount   Float    @default(0)
  balanceAmount Float   @default(0)
  
  usedInInvoiceId String?
  expiryDate   DateTime?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// VAN SALES / DIRECT STORE DELIVERY MODELS
// ============================================

model VanLoad {
  id           String   @id @default(cuid())
  companyName  String
  loadNo       String   @unique
  
  vehicleId    String
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  
  driverId     String
  driver       Employee @relation(fields: [driverId], references: [id])
  
  // Status workflow
  status       String   @default("LOADING") // LOADING, DISPATCHED, IN_TRANSIT, COMPLETED, CANCELLED
  
  loadedAt     DateTime?
  dispatchedAt DateTime?
  completedAt  DateTime?
  
  // Route info
  plannedRoute String?  // JSON array of customer IDs
  actualRoute  String?  // JSON array of visited customer IDs
  
  items        VanLoadItem[]
  sales        VanSale[]
  
  // Settlement
  totalLoaded  Float    @default(0)
  totalSold    Float    @default(0)
  totalCash    Float    @default(0)
  totalCredit  Float    @default(0)
  totalReturns Float    @default(0)
  
  isSettled    Boolean  @default(false)
  settledAt    DateTime?
  settledBy    String?
  settlementNotes String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VanLoadItem {
  id          String   @id @default(cuid())
  vanLoadId   String
  vanLoad     VanLoad  @relation(fields: [vanLoadId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  loadedQty   Int
  soldQty     Int      @default(0)
  returnedQty Int      @default(0)
  damagedQty  Int      @default(0)
  
  unitPrice   Float
}

model VanSale {
  id          String   @id @default(cuid())
  vanLoadId   String
  vanLoad     VanLoad  @relation(fields: [vanLoadId], references: [id])
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  
  invoiceId   String?  // Generated invoice ID
  
  amount      Float
  paymentMode String   // CASH, CREDIT, UPI
  
  // Location of sale
  lat         Float?
  lng         Float?
  
  items       String?  // JSON array of sold items
  
  createdAt   DateTime @default(now())
}

model Asset {
  id               String   @id @default(cuid())
  companyName      String
  
  // Asset Details
  assetType        String   // VEHICLE, EQUIPMENT, PROPERTY, FURNITURE, ELECTRONICS
  name             String
  description      String?
  serialNumber     String?
  
  // Financial
  purchaseValue    Float
  currentValue     Float
  purchaseDate     DateTime
  depreciationRate Float    @default(10) // Percentage per year
  
  // Location & Status
  location         String?
  status           String   @default("ACTIVE") // ACTIVE, SOLD, DISPOSED, UNDER_REPAIR
  
  // Tracking
  assignedTo       String?  // Employee ID or name
  maintenanceNotes String?  // Text field for maintenance history
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([companyName])
  @@index([companyName, status])
}

model CAAuditLog {
  id          String   @id @default(cuid())
  companyName String
  caUserEmail String?
  action      String
  details     String?
  createdAt   DateTime @default(now())

  @@index([companyName, createdAt])
}

model CAInviteToken {
  id          String   @id @default(cuid())
  email       String
  companyName String
  token       String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([email, companyName])
  @@index([expiresAt])
}

