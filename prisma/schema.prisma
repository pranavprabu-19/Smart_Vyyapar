// SmartVyapar V2 — Strong Database Schema (Postgres)
//
// Conventions (see prisma/README.md for full details):
//   - Tenant scope is enforced via `companyId` FK to `Company`.
//     `companyName` is kept as a denormalized snapshot only.
//   - Money fields use Decimal(14, 2). Quantities use Int. Coordinates and
//     ratios stay Float. Tax rates use Decimal(5, 2).
//   - Structured payloads use Json (jsonb on Postgres) instead of TEXT JSON.
//   - Soft-deletable entities expose `deletedAt`; the Prisma client extension
//     in src/lib/db.ts filters out soft-deleted rows by default.
//   - Tenant-scoped business identifiers (invoiceNo, sku, gstin, etc.) are
//     unique per tenant via composite uniques.

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// CORE TENANT
// ============================================

model Company {
  id      String  @id @default(cuid())
  name    String  @unique
  address String
  city    String?
  state   String?
  pincode String?
  phone   String?
  email   String?
  gstin   String?

  bankName  String?
  accountNo String?
  ifscCode  String?
  branch    String?

  logoUrl      String?
  signatureUrl String?

  whatsappApiKey    String?
  whatsappPhoneId   String?
  invoiceTemplateId String?

  emailSmtpHost String?
  emailUser     String?
  emailPassword String?

  ewayProvider            String?
  ewayEnvironment         String    @default("SANDBOX")
  ewayEnabled             Boolean   @default(false)
  ewayClientId            String?
  ewayClientSecret        String?
  ewayUsername            String?
  ewayPassword            String?
  ewayGstin               String?
  ewayCredentialUpdatedAt DateTime?
  ewayLastTestedAt        DateTime?
  ewayLastTestStatus      String?
  ewayLastTestMessage     String?

  ewayAuditLogs      EWayAuditLog[]
  invoices           Invoice[]
  customers          Customer[]
  products           Product[]
  employees          Employee[]
  godowns            Godown[]
  trips              Trip[]
  vehicles           Vehicle[]
  beats              Beat[]
  visits             Visit[]
  orders             Order[]
  schemes            Scheme[]
  payments           Payment[]
  paymentReminders   PaymentReminder[]
  reminderTemplates  ReminderTemplate[]
  salesReturns       SalesReturn[]
  creditNotes        CreditNote[]
  vanLoads           VanLoad[]
  assets             Asset[]
  photos             Photo[]
  caAuditLogs        CAAuditLog[]
  caInviteTokens     CAInviteToken[]
  creditLimitActions CreditLimitAction[]
  auditLogs          AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// SALES & INVOICING
// ============================================

model Invoice {
  id           String  @id @default(cuid())
  invoiceNo    String
  companyId    String
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName  String // denormalized snapshot
  customerName String

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  totalAmount Decimal  @db.Decimal(14, 2)
  date        DateTime
  paymentMode String
  status      String   @default("PAID")

  dueDate    DateTime?
  paidAmount Decimal   @default(0) @db.Decimal(14, 2)

  customerDetails Json
  billingAddress  String

  items               InvoiceItem[]
  payments            Payment[]
  salesReturns        SalesReturn[]
  reminders           PaymentReminder[]
  creditNotesUsedHere CreditNote[]      @relation("CreditNoteUsedInvoice")
  ordersFulfilled     Order[]           @relation("OrderInvoice")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([companyId, invoiceNo])
  @@index([companyId, date])
  @@index([companyId, status, dueDate])
  @@index([customerId])
  @@index([companyId, deletedAt])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId   String
  description String
  quantity    Int
  price       Decimal @db.Decimal(14, 2)
  costPrice   Decimal @default(0) @db.Decimal(14, 2)
  hsn         String?
  gstRate     Decimal @default(18.0) @db.Decimal(5, 2)

  @@index([invoiceId])
}

// ============================================
// USERS, EMPLOYEES, ATTENDANCE, PAYROLL
// ============================================

model User {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  role     String
  password String

  companyName String?
  employeeId  String?   @unique
  employee    Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String
  employeeId  String

  name    String
  role    String
  email   String?
  phone   String?
  address String?
  aadhaar String?
  pan     String?

  salaryType String  @default("MONTHLY")
  baseSalary Decimal @default(0) @db.Decimal(14, 2)

  status      String   @default("ACTIVE")
  joiningDate DateTime @default(now())

  attendance Attendance[]
  invoices   Invoice[]
  payroll    Payroll[]

  beats    Beat[]
  visits   Visit[]
  orders   Order[]
  vanLoads VanLoad[]
  user     User?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([companyId, employeeId])
  @@index([companyId, status])
  @@index([companyId, deletedAt])
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date          DateTime
  status        String
  checkIn       String?
  checkOut      String?
  overtimeHours Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
}

model Payroll {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month String
  year  Int

  baseSalary     Decimal @db.Decimal(14, 2)
  attendanceDays Float
  earnedSalary   Decimal @db.Decimal(14, 2)
  bonus          Decimal @default(0) @db.Decimal(14, 2)
  incentives     Decimal @default(0) @db.Decimal(14, 2)
  deductions     Decimal @default(0) @db.Decimal(14, 2)
  netSalary      Decimal @db.Decimal(14, 2)

  status      String    @default("PENDING")
  paymentDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month])
  @@index([employeeId, year])
}

// ============================================
// PRODUCT, GODOWN, STOCK
// ============================================

model Product {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String  @default("Sai Associates")
  sku         String
  name        String
  category    String  @default("General")

  price           Decimal @db.Decimal(14, 2)
  stock           Int     @default(0)
  image           String?
  minStock        Int     @default(10)
  costPrice       Decimal @default(0) @db.Decimal(14, 2)
  reorderQuantity Int     @default(50)
  supplierEmail   String?
  gstRate         Decimal @default(18.0) @db.Decimal(5, 2)

  isLiquidationCandidate Boolean   @default(false)
  liquidationFlaggedAt   DateTime?
  liquidationReason      String?

  stocks       Stock[]
  orderItems   OrderItem[]
  vanLoadItems VanLoadItem[]
  returnItems  ReturnItem[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([companyId, sku])
  @@index([companyId, category])
  @@index([companyId, deletedAt])
}

model Godown {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String?
  name        String
  location    String?
  manager     String?
  contact     String?

  stocks Stock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model Stock {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  godownId String
  godown   Godown @relation(fields: [godownId], references: [id], onDelete: Cascade)

  quantity Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, godownId])
}

// ============================================
// CUSTOMERS
// ============================================

model Customer {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String  @default("Sai Associates")
  name        String
  address     String
  state       String
  gstin       String?
  phone       String?
  email       String?

  lat     Float?
  lng     Float?
  mapLink String?

  balance      Decimal @default(0) @db.Decimal(14, 2)
  totalRevenue Decimal @default(0) @db.Decimal(14, 2)

  invoices      Invoice[]
  lastInvoiceNo String?

  beatCustomers BeatCustomer[]
  visits        Visit[]
  orders        Order[]
  credit        CustomerCredit?
  payments      Payment[]
  reminders     PaymentReminder[]
  salesReturns  SalesReturn[]
  creditNotes   CreditNote[]
  vanSales      VanSale[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([companyId, gstin])
  @@index([companyId, phone])
  @@index([companyId, deletedAt])
}

// ============================================
// E-WAY AUDIT
// ============================================

model EWayAuditLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  action    String
  status    String
  message   String?
  provider  String?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
}

// ============================================
// TRIPS, STOPS, VEHICLES
// ============================================

model Trip {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String  @default("Sai Associates")
  driverName  String
  vehicleNo   String

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  status        String    @default("NOT_STARTED")
  startTime     DateTime?
  endTime       DateTime?
  startLocation Json?
  totalDistance Float     @default(0)

  stops TripStop[]

  fuelCost  Decimal @default(0) @db.Decimal(14, 2)
  foodCost  Decimal @default(0) @db.Decimal(14, 2)
  otherExp  Decimal @default(0) @db.Decimal(14, 2)
  allowance Decimal @default(0) @db.Decimal(14, 2)

  startReading Float @default(0)
  endReading   Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([companyId, createdAt])
}

model TripStop {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  customerName String
  address      String
  items        String

  status    String    @default("PENDING")
  timestamp DateTime?

  lat Float
  lng Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  regNo     String  @unique
  model     String
  type      String
  status    String  @default("ACTIVE")
  fuelType  String?

  totalDistance   Float     @default(0)
  lastServiceDate DateTime?

  details Json?

  trips    Trip[]
  vanLoads VanLoad[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
}

// ============================================
// PHOTOS
// ============================================

model Photo {
  id        String   @id @default(cuid())
  url       String
  timestamp DateTime @default(now())

  lat      Float
  lng      Float
  address  String?
  accuracy Float?
  isMock   Boolean @default(false)

  stockSnapshot Json?

  userName    String
  userRole    String
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, timestamp])
}

// ============================================
// BEAT PLANNING & ROUTE OPTIMIZATION
// ============================================

model Beat {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String
  name        String
  description String?
  dayOfWeek   Int

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  customers BeatCustomer[]
  visits    Visit[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name, dayOfWeek])
  @@index([companyId, employeeId])
}

model BeatCustomer {
  id     String @id @default(cuid())
  beatId String
  beat   Beat   @relation(fields: [beatId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  sequence Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([beatId, customerId])
}

model Visit {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  beatId String?
  beat   Beat?   @relation(fields: [beatId], references: [id])

  checkInTime DateTime
  checkInLat  Float
  checkInLng  Float

  checkOutTime DateTime?
  checkOutLat  Float?
  checkOutLng  Float?

  status   String  @default("IN_PROGRESS")
  notes    String?
  photoIds Json?

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  duration Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, employeeId, checkInTime])
  @@index([customerId])
}

// ============================================
// ORDERS
// ============================================

model Order {
  id          String  @id @default(cuid())
  orderNo     String
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  status String @default("DRAFT")

  subtotal       Decimal @db.Decimal(14, 2)
  discountAmount Decimal @default(0) @db.Decimal(14, 2)
  schemeDiscount Decimal @default(0) @db.Decimal(14, 2)
  taxAmount      Decimal @default(0) @db.Decimal(14, 2)
  totalAmount    Decimal @db.Decimal(14, 2)

  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?

  dispatchedAt  DateTime?
  deliveredAt   DateTime?
  deliveryNotes String?

  invoiceId String?
  invoice   Invoice? @relation("OrderInvoice", fields: [invoiceId], references: [id])

  items          OrderItem[]
  appliedSchemes OrderScheme[]
  visits         Visit[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([companyId, orderNo])
  @@index([companyId, status, createdAt])
  @@index([customerId])
  @@index([companyId, deletedAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Decimal @db.Decimal(14, 2)
  discount Decimal @default(0) @db.Decimal(14, 2)
  gstRate  Decimal @default(18.0) @db.Decimal(5, 2)
  total    Decimal @db.Decimal(14, 2)
}

// ============================================
// SCHEMES & PROMOTIONS
// ============================================

model Scheme {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String
  name        String
  description String?

  type String

  minQuantity Int?
  minAmount   Decimal? @db.Decimal(14, 2)
  buyQuantity Int?
  getQuantity Int?

  discountPercent Decimal? @db.Decimal(5, 2)
  discountAmount  Decimal? @db.Decimal(14, 2)
  freeProductId   String?

  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)

  applicableProducts   Json?
  applicableCustomers  Json?
  customerTiers        Json?
  applicableCategories Json?

  budget              Decimal? @db.Decimal(14, 2)
  usedBudget          Decimal  @default(0) @db.Decimal(14, 2)
  maxUsagePerCustomer Int?

  appliedOrders OrderScheme[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, isActive, endDate])
}

model OrderScheme {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  schemeId String
  scheme   Scheme @relation(fields: [schemeId], references: [id])

  discount    Decimal @db.Decimal(14, 2)
  description String?
}

// ============================================
// CREDIT & COLLECTION
// ============================================

model CustomerCredit {
  id String @id @default(cuid())

  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  creditLimit     Decimal @default(0) @db.Decimal(14, 2)
  currentBalance  Decimal @default(0) @db.Decimal(14, 2)
  availableCredit Decimal @default(0) @db.Decimal(14, 2)

  lastPaymentDate   DateTime?
  lastPaymentAmount Decimal?  @db.Decimal(14, 2)

  creditDays Int    @default(30)
  tier       String @default("C")

  isBlocked   Boolean             @default(false)
  blockReason String?
  blockedAt   DateTime?
  riskActions CreditLimitAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreditLimitAction {
  id                 String         @id @default(cuid())
  customerCreditId   String
  customerCredit     CustomerCredit @relation(fields: [customerCreditId], references: [id], onDelete: Cascade)
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName        String
  previousLimit      Decimal        @db.Decimal(14, 2)
  newLimit           Decimal        @db.Decimal(14, 2)
  riskScore          Float
  policyAction       String
  reason             String?
  notificationStatus String         @default("PENDING")
  createdAt          DateTime       @default(now())

  @@index([companyId, createdAt])
}

model Payment {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String
  paymentNo   String

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  amount    Decimal @db.Decimal(14, 2)
  mode      String
  reference String?

  chequeNo   String?
  chequeDate DateTime?
  bankName   String?

  status String @default("RECEIVED")

  collectedBy String?
  collectedAt DateTime @default(now())

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, paymentNo])
  @@index([companyId, customerId, collectedAt])
  @@index([invoiceId])
}

model PaymentReminder {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  dueAmount   Decimal  @db.Decimal(14, 2)
  dueDate     DateTime
  daysPastDue Int      @default(0)

  messageText String?

  channel     String
  phoneNumber String?

  sentAt       DateTime?
  deliveredAt  DateTime?
  status       String    @default("PENDING")
  errorMessage String?

  reminderType String @default("FIRST")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status, dueDate])
  @@index([customerId])
}

model ReminderTemplate {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String
  name        String

  type            String
  messageTemplate String
  triggerDays     Int    @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

// ============================================
// RETURNS & CLAIMS
// ============================================

model SalesReturn {
  id          String  @id @default(cuid())
  returnNo    String
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  reason      String
  description String?

  status String @default("PENDING")

  totalAmount Decimal @db.Decimal(14, 2)

  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?

  stockAdjusted Boolean @default(false)

  items       ReturnItem[]
  creditNotes CreditNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, returnNo])
  @@index([companyId, status])
}

model ReturnItem {
  id       String      @id @default(cuid())
  returnId String
  return   SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  price     Decimal @db.Decimal(14, 2)
  total     Decimal @db.Decimal(14, 2)
  reason    String?
  condition String?
}

model CreditNote {
  id           String  @id @default(cuid())
  creditNoteNo String
  companyId    String
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName  String

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  returnId String?
  return   SalesReturn? @relation(fields: [returnId], references: [id])

  amount Decimal @db.Decimal(14, 2)
  reason String

  status        String  @default("ISSUED")
  usedAmount    Decimal @default(0) @db.Decimal(14, 2)
  balanceAmount Decimal @default(0) @db.Decimal(14, 2)

  usedInInvoiceId String?
  usedInInvoice   Invoice?  @relation("CreditNoteUsedInvoice", fields: [usedInInvoiceId], references: [id])
  expiryDate      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, creditNoteNo])
  @@index([companyId, status])
  @@index([customerId])
}

// ============================================
// VAN SALES / DSD
// ============================================

model VanLoad {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String
  loadNo      String

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  driverId String
  driver   Employee @relation(fields: [driverId], references: [id])

  status String @default("LOADING")

  loadedAt     DateTime?
  dispatchedAt DateTime?
  completedAt  DateTime?

  plannedRoute Json?
  actualRoute  Json?

  items VanLoadItem[]
  sales VanSale[]

  totalLoaded  Decimal @default(0) @db.Decimal(14, 2)
  totalSold    Decimal @default(0) @db.Decimal(14, 2)
  totalCash    Decimal @default(0) @db.Decimal(14, 2)
  totalCredit  Decimal @default(0) @db.Decimal(14, 2)
  totalReturns Decimal @default(0) @db.Decimal(14, 2)

  isSettled       Boolean   @default(false)
  settledAt       DateTime?
  settledBy       String?
  settlementNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, loadNo])
  @@index([companyId, status])
}

model VanLoadItem {
  id        String  @id @default(cuid())
  vanLoadId String
  vanLoad   VanLoad @relation(fields: [vanLoadId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  loadedQty   Int
  soldQty     Int @default(0)
  returnedQty Int @default(0)
  damagedQty  Int @default(0)

  unitPrice Decimal @db.Decimal(14, 2)
}

model VanSale {
  id        String  @id @default(cuid())
  vanLoadId String
  vanLoad   VanLoad @relation(fields: [vanLoadId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  invoiceId String?

  amount      Decimal @db.Decimal(14, 2)
  paymentMode String

  lat Float?
  lng Float?

  items Json?

  createdAt DateTime @default(now())

  @@index([vanLoadId])
}

// ============================================
// ASSETS
// ============================================

model Asset {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String

  assetType    String
  name         String
  description  String?
  serialNumber String?

  purchaseValue    Decimal  @db.Decimal(14, 2)
  currentValue     Decimal  @db.Decimal(14, 2)
  purchaseDate     DateTime
  depreciationRate Decimal  @default(10) @db.Decimal(5, 2)

  location String?
  status   String  @default("ACTIVE")

  assignedTo       String?
  maintenanceNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status])
}

// ============================================
// CA ACCESS
// ============================================

model CAAuditLog {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String
  caUserEmail String?
  action      String
  details     String?
  createdAt   DateTime @default(now())

  @@index([companyId, createdAt])
}

model CAInviteToken {
  id          String    @id @default(cuid())
  email       String
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName String
  token       String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([email, companyId])
  @@index([expiresAt])
}

// ============================================
// AUDIT LOG (V2)
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  actor     String?
  entity    String
  entityId  String
  action    String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([companyId, entity, entityId])
  @@index([companyId, createdAt])
}
